@model Aiursoft.CorpHome.Views.Shared.Components.MarketingFooter.MarketingFooterViewModel
@using Microsoft.AspNetCore.Localization
<footer class="py-5 bg-dark">
    <div class="container">
        <div class="row mb-4">
            @* Col 1: Brand *@
            <div class="col-12 col-lg-3 mb-4 mb-lg-0">
                <div class="mb-3">
                    <img src="@Model.LogoUrl" alt="logo" style="width: 24px; height: 24px;" loading="lazy" />
                </div>
                <p class="text-white-50">
                    @Localizer["Aiursoft is dedicated to bringing the spirit of open-source and free software to every enterprise and individual."]
                </p>
                <div class="dropdown mt-3 mb-3">
                    @{
                        var currentCulture = ViewContext.HttpContext.Features
                            .Get<IRequestCultureFeature>()?
                            .RequestCulture.Culture.Name;
                    }
                    <form asp-controller="Culture" asp-action="Set" method="post" class="d-inline" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                        <select name="culture" onchange="this.form.submit()" class="form-select form-select-sm w-auto">
                            @foreach (var culture in Aiursoft.WebTools.OfficialPlugins.LocalizationPlugin.SupportedCultures)
                            {
                                <option value="@culture.Key"
                                        selected="@(culture.Key == currentCulture ? "selected" : null)">
                                    @culture.Value
                                </option>
                            }
                        </select>
                    </form>
                </div>
            </div>
            @* Col 2: Solutions *@
            <div class="col-6 col-lg-2 mb-3 mb-lg-0">
                <h4 class="text-light fs-5">@Localizer["Solutions"]</h4>
                <ul class="list-unstyled ps-0 mb-0 mt-3">
                    <li class="mt-2">
                        <a asp-controller="Home" asp-action="Anduinos" class="text-white-50">@Localizer["AnduinOS Enterprise"]</a>
                    </li>
                    <li class="mt-2">
                        <a asp-controller="Home" asp-action="Substratum" class="text-white-50">@Localizer["Substratum"]</a>
                    </li>
                </ul>
            </div>
            @* Col 3: Resources *@
            <div class="col-6 col-lg-2 mb-3 mb-lg-0">
                <h4 class="text-light fs-5">@Localizer["Resources"]</h4>
                <ul class="list-unstyled ps-0 mb-0 mt-3">
                    <li class="mt-2">
                        <a href="https://news.aiursoft.com" target="_blank" class="text-white-50">@Localizer["News"]</a>
                    </li>
                    <li class="mt-2">
                        <a href="https://github.com/aiursoftweb" target="_blank" class="text-white-50">@Localizer["Source Code"]</a>
                    </li>
                </ul>
            </div>
            @* Col 4: Company *@
            <div class="col-6 col-lg-3 mb-3 mb-lg-0">
                <h4 class="text-light fs-5">@Localizer["Company"]</h4>
                <ul class="list-unstyled ps-0 mb-0 mt-3">
                    <li class="mt-2">
                        <a asp-controller="Home" asp-action="KnowUs" class="text-white-50">@Localizer["Get to know us"]</a>
                    </li>
                    <li class="mt-2">
                        <a asp-controller="Home" asp-action="Contact" class="text-white-50">@Localizer["Contact"]</a>
                    </li>
                </ul>
            </div>
            @* Col 5: Legal *@
            <div class="col-6 col-lg-2 mb-3 mb-lg-0">
                <h4 class="text-light fs-5">@Localizer["Legal"]</h4>
                <ul class="list-unstyled ps-0 mb-0 mt-3">
                    <li class="mt-2">
                        <a asp-controller="Home" asp-action="Terms" class="text-white-50">@Localizer["Terms of Service"]</a>
                    </li>
                    <li class="mt-2">
                        <a asp-controller="Home" asp-action="Privacy" class="text-white-50">@Localizer["Privacy Policy"]</a>
                    </li>
                </ul>
            </div>
        </div>
        @* Social *@
        <div class="row">
            <div class="col-lg-12">
                <div class="d-flex justify-content-center gap-3 mb-3">
                    <a href="https://github.com/aiursoftweb" target="_blank" class="text-white-50 fs-5" title="GitHub">
                        <i class="fa-brands fa-github"></i>
                    </a>
                    <a href="https://www.linkedin.com/company/aiursoft-limited/" target="_blank" class="text-white-50 fs-5" title="LinkedIn">
                        <i class="fa-brands fa-linkedin"></i>
                    </a>
                </div>
            </div>
        </div>
        @* Copyright *@
        <div class="row">
            <div class="col-lg-12">
                <p class="text-white-50 text-center mb-0">
                    © @DateTime.Now.Year <a href="@Model.BrandHomeUrl" target="_blank">@Model.CompanyName</a>
                    @if (!string.IsNullOrWhiteSpace(Model.Icp) && System.Globalization.CultureInfo.CurrentCulture.Name == "zh-CN")
                    {
                        <span> | </span>
                        <a href="https://beian.miit.gov.cn/" target="_blank">@Model.Icp</a>
                    }
                </p>
            </div>
        </div>
    </div>
</footer>
