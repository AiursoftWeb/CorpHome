@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 5: Voxihost Partnership
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="immersive-section position-relative w-100 overflow-hidden d-flex align-items-center border-top border-white-10">

    <div class="immersive-bg-right">
        <div class="bg-image-wrapper clean-wrapper">
            <img src="~/images/voxihost_website.png" alt="@Localizer["Voxihost Cloud Infrastructure"]" class="img-fluid object-fit-cover w-100 h-100">
        </div>
        <div class="bg-overlay"></div>
    </div>

    <div class="container position-relative z-2 py-5">
        <div class="row">
            <div class="col-lg-6 col-md-12">

                <div class="mb-5 text-start pe-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-info me-2"><i class="fas fa-server"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Strategic Partner"]</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        <span class="text-primary">@Localizer["Voxihost"]</span><br>
                        @Localizer["Paving the Way for Your Business."]
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        @Localizer["With reliable cloud infrastructure, your business can grow reliably alongside Aiursoft."]
                    </p>
                </div>

                <div class="row g-3 pe-lg-4">

                    @* Card 1: Deep Collaboration *@
                    <div class="col-md-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-info-subtle text-info rounded-3 me-3 mb-3">
                                    <i class="fas fa-handshake fa-lg"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Deep Collaboration"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm">@Localizer["All Aiursoft servers are sourced from Voxihost. We help clients land on Voxihost infrastructure."]</p>
                            </div>
                        </div>
                    </div>

                    @* Card 2: Transparent Pricing *@
                    <div class="col-md-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-success-subtle text-success rounded-3 me-3 mb-3">
                                    <i class="fas fa-tag fa-lg"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Transparent & Affordable"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm">@Localizer["Voxihost offers transparent, cost-effective cloud and generously sponsors Aiursoft's Open-source work."]</p>
                            </div>
                        </div>
                    </div>

                    @* Card 3: Full Stack Hosting *@
                    <div class="col-12">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4 d-flex align-items-center">
                                <div class="icon-box-sm bg-white-10 text-white rounded-3 me-3">
                                    <i class="fas fa-cubes"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-white mb-1 fs-6">@Localizer["Complete Business Hosting"]</h5>
                                    <p class="text-gray-400 mb-0">@Localizer["With Voxihost, Aiursoft helps enterprises host Email, authentication, cloud drives, employee portals, monitoring, and AI."]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
