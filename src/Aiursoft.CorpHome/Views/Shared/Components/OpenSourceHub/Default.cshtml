@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 2: Open-Source Microservices Hub
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="py-5" style="background-color: #161a27;">
    <div class="container">

        @* Header text *@
        <div class="row justify-content-center mb-5 text-center">
            <div class="col-lg-8 col-md-10">
                <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Open-Source Solutions"]</span>
                <h2 class="display-6 fw-light mb-4 text-white">@Localizer["The Open-source world already has the solutions you need."]</h2>
                <p class="lead text-gray-400 mb-2">@Localizer["You don't need to purchase expensive monopolistic services. A small $5/month server can rapidly power your business."]</p>

                <!-- Condensed and moved text below the vector graphic -->
                <div class="text-center mt-4">
                    <p class="text-gray-400" style="font-size: smaller;">@Localizer["Combine Open-source tools on GitHub and Hugging Face — no enterprise licenses needed."]</p>
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-4 mt-4">
                    <a href="https://github.com/AiursoftWeb" target="_blank" class="btn btn-primary px-4 py-2">@Localizer["Explore Our Projects"]</a>
                    <a href="/anduinos" class="text-primary text-decoration-none d-inline-flex align-items-center gap-2 fw-medium">
                        @Localizer["Discover AnduinOS"] <span>&rarr;</span>
                    </a>
                </div>
            </div>
        </div>

        @* Architecture Diagram (desktop) *@
        <div class="diagram-container">
            @* Background SVG lines *@
            <svg class="bg-lines" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet">
                <circle cx="500" cy="250" r="100" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"></circle>
                <circle cx="500" cy="250" r="180" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"></circle>
                <circle cx="500" cy="250" r="280" fill="none" stroke="rgba(255,255,255,0.02)" stroke-width="1"></circle>

                @* Data bus lines *@
                <path class="line-path" d="M 500 0 L 500 500" />
                <path class="line-path" d="M 0 250 L 1000 250" />
                <path class="line-path" d="M 0 160 L 260 160 C 330 160, 330 225, 400 225 L 600 225 C 650 225, 650 150, 700 150 L 1000 150" />
                <path class="line-path" d="M 0 360 L 340 360 C 370 360, 370 275, 400 275 L 600 275 C 680 275, 680 380, 760 380 L 1000 380" />

                @* Connection dots *@
                <circle class="line-dot" cx="180" cy="250" r="4" />
                <circle class="line-dot" cx="880" cy="250" r="4" />
                <circle class="line-dot" cx="120" cy="160" r="4" />
                <circle class="line-dot" cx="920" cy="380" r="4" />
                <circle class="line-dot" cx="500" cy="60" r="4" />
            </svg>

            @* Center hub node – AnduinOS *@
            <a href="/anduinos" class="node-base node-center float-in" title="AnduinOS">
                <img src="~/images/app_icons/anduinos.webp" alt="AnduinOS" />
            </a>

            @* Outer nodes – 8 app icons positioned around the hub *@
            @* Top *@
            <a href="https://auth.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 50%; top: 14%;" title="Authentik">
                <img src="~/images/app_icons/authentik.webp" alt="Authentik" />
            </a>
            <div class="node-label float-in" style="left: 50%; top: 3%; transform: translateX(-50%);">@Localizer["Authentik"]</div>

            @* Top-right *@
            <a href="https://nextcloud.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 76%; top: 22%;" title="Nextcloud">
                <img src="~/images/app_icons/nextcloud.webp" alt="Nextcloud" />
            </a>
            <div class="node-label float-in" style="left: 84%; top: 17%;">@Localizer["Nextcloud"]</div>

            @* Right *@
            <a href="https://polls.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 86%; top: 50%;" title="Polls">
                <img src="~/images/app_icons/polls.svg" alt="Polls" />
            </a>
            <div class="node-label float-in" style="left: 93%; top: 47%;">@Localizer["Polls"]</div>

            @* Bottom-right *@
            <a href="https://ollama.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 76%; top: 78%;" title="Ollama Gateway">
                <img src="~/images/app_icons/ollamagateway.svg" alt="Ollama Gateway" />
            </a>
            <div class="node-label float-in" style="left: 84%; top: 80%;">@Localizer["Ollama Gateway"]</div>

            @* Bottom *@
            <a href="https://zotregistry.dev/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 50%; top: 86%;" title="Zot Registry">
                <img src="~/images/app_icons/zot.webp" alt="Zot" />
            </a>
            <div class="node-label float-in" style="left: 50%; top: 96%; transform: translateX(-50%);">@Localizer["Zot"]</div>

            @* Bottom-left *@
            <a href="https://employee.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 24%; top: 78%;" title="Employee Center">
                <img src="~/images/app_icons/employee.svg" alt="Employee Center" />
            </a>
            <div class="node-label float-in" style="left: 8%; top: 80%;">@Localizer["Employee Center"]</div>

            @* Left *@
            <a href="https://stathub.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 14%; top: 50%;" title="StatHub">
                <img src="~/images/app_icons/stathub.svg" alt="StatHub" />
            </a>
            <div class="node-label float-in" style="left: 2%; top: 47%;">@Localizer["StatHub"]</div>

            @* Top-left *@
            <a href="https://kanban.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="node-base node-icon float-in" style="left: 24%; top: 22%;" title="Kanban">
                <img src="~/images/app_icons/kanban.svg" alt="Kanban" />
            </a>
            <div class="node-label float-in" style="left: 10%; top: 17%;">@Localizer["Kanban"]</div>
        </div>

        @* Mobile fallback: simple icon grid *@
        <div class="diagram-mobile-fallback flex-wrap justify-content-center gap-4 py-4" style="display: none;">
            <a href="/anduinos" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/anduinos.webp" alt="AnduinOS" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["AnduinOS"]</div>
            </a>
            <a href="https://auth.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/authentik.webp" alt="Authentik" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Authentik"]</div>
            </a>
            <a href="https://nextcloud.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/nextcloud.webp" alt="Nextcloud" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Nextcloud"]</div>
            </a>
            <a href="https://polls.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/polls.svg" alt="Polls" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Polls"]</div>
            </a>
            <a href="https://ollama.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/ollamagateway.svg" alt="Ollama Gateway" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Ollama Gateway"]</div>
            </a>
            <a href="https://zotregistry.dev/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/zot.webp" alt="Zot" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Zot"]</div>
            </a>
            <a href="https://employee.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/employee.svg" alt="Employee Center" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Employee Center"]</div>
            </a>
            <a href="https://stathub.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/stathub.svg" alt="StatHub" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["StatHub"]</div>
            </a>
            <a href="https://kanban.aiursoft.com/" target="_blank" rel="noopener noreferrer" class="text-center float-in text-decoration-none">
                <img src="~/images/app_icons/kanban.svg" alt="Kanban" width="48" height="48" class="rounded-3 mb-1" />
                <div class="extra-small text-gray-400">@Localizer["Kanban"]</div>
            </a>
        </div>

    </div>
</section>
