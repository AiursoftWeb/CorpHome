@* ── Substratum Ecosystem — Two-ring radial diagram ── *@
<section class="py-5" style="background-color: #161a27;">
    <div class="container">

        <div class="row justify-content-center mb-4 text-center">
            <div class="col-lg-8 col-md-10">
                <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Unified Platform"]</span>
                <h2 class="display-6 fw-light mb-3 text-white">@Localizer["One platform. Every tool your team needs."]</h2>
                <p class="lead text-gray-400">@Localizer["Substratum unifies your entire software stack — from identity and source control to media, collaboration, and developer tools — on a single self-hosted server."]</p>
            </div>
        </div>

        @* ──────────────────────────────────────
           Two-ring radial diagram (desktop)
           Canvas: 1000 × 500, center (500, 250)

           Center      : AnduinOS
           Inner ring  : Kanban (0°) · StatHub (120°) · Nextcloud (240°)   rx=130, ry=65
           Outer ring  : 10 nodes at 36° steps, rx=380, ry=190
             0°  Authentik    → 50%, 12%
            36°  Apkg         → 72%, 19%
            72°  Mark To HTML → 86%, 38%
           108°  Polls        → 86%, 62%
           144°  Employee Ctr → 72%, 81%
           180°  Kanban       → 50%, 88%
           216°  AiurDrive    → 28%, 81%
           252°  Warp         → 14%, 62%
           288°  Git Mirror   → 14%, 38%
           324°  C++ Runner   → 28%, 19%
           ────────────────────────────────────── *@
        <div class="diagram-container">

            @* SVG background — 2 orbit ellipses + 10 radial spokes *@
            <svg class="bg-lines" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet">

                @* Faint innermost halo *@
                <ellipse cx="500" cy="250" rx="55" ry="28"
                         fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

                @* Inner-orbit ring *@
                <ellipse cx="500" cy="250" rx="130" ry="65"
                         fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"
                         stroke-dasharray="6 4"/>

                @* Outer-orbit ring *@
                <ellipse cx="500" cy="250" rx="380" ry="190"
                         fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>

                @* 10 radial spokes — extend from center to canvas edges *@
                <line x1="500" y1="250" x2="500" y2="0"   stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="682" y2="0"   stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="1000" y2="88" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="1000" y2="412" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="682" y2="500" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="500" y2="500" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="318" y2="500" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="0" y2="412"   stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="0" y2="88"    stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <line x1="500" y1="250" x2="318" y2="0"   stroke="rgba(255,255,255,0.03)" stroke-width="1"/>

                @* Center dot *@
                <circle cx="500" cy="250" r="4" fill="rgba(255,255,255,0.3)"/>
            </svg>

            @* Center hub node — AnduinOS *@
            <a href="/anduinos" class="node-base node-center float-in" title="AnduinOS">
                <img src="~/images/app_icons/anduinos.webp" alt="AnduinOS" />
            </a>

            @* ══ INNER RING — 3 nodes at 0°, 120°, 240° ══ *@

            @* Kanban — top (0°), SVG(500,185), CSS 50%/37% *@
            <div class="node-base node-icon float-in" style="left: 50%; top: 37%;" title="Kanban">
                <img src="~/images/app_icons/kanban.svg" alt="Kanban" />
            </div>
            <div class="node-label float-in" style="left: 50%; top: 26%; transform: translateX(-50%);">Kanban</div>

            @* StatHub — bottom-right (120°), SVG(613,283), CSS 61%/57% *@
            <div class="node-base node-icon float-in" style="left: 61%; top: 57%;" title="StatHub">
                <img src="~/images/app_icons/stathub.svg" alt="StatHub" />
            </div>
            <div class="node-label float-in" style="left: 67%; top: 62%;">StatHub</div>

            @* Nextcloud — bottom-left (240°), SVG(387,283), CSS 39%/57% *@
            <div class="node-base node-icon float-in" style="left: 39%; top: 57%;" title="Nextcloud">
                <img src="~/images/app_icons/nextcloud.webp" alt="Nextcloud" />
            </div>
            <div class="node-label float-in" style="right: 64%; top: 62%;">Nextcloud</div>

            @* ══ OUTER RING — 10 nodes at 36° steps ══ *@

            @* Authentik — top (0°), CSS 50%/12% *@
            <div class="node-base node-icon float-in" style="left: 50%; top: 12%;" title="Authentik — Identity & SSO">
                <img src="~/images/app_icons/authentik.webp" alt="Authentik" />
            </div>
            <div class="node-label float-in" style="left: 50%; top: 0%; transform: translateX(-50%);">Authentik</div>

            @* Apkg — 36°, CSS 72%/19% *@
            <div class="node-base node-icon float-in" style="left: 72%; top: 19%;" title="Apkg — Private APT Repository">
                <img src="~/images/app_icons/apkg.svg" alt="Apkg" />
            </div>
            <div class="node-label float-in" style="left: 77%; top: 8%;">Apkg</div>

            @* Mark To HTML — 72°, CSS 86%/38% *@
            <div class="node-base node-icon float-in" style="left: 86%; top: 38%;" title="Mark To HTML — Document conversion">
                <img src="~/images/app_icons/mth.svg" alt="Mark To HTML" />
            </div>
            <div class="node-label float-in" style="left: 95%; top: 37%;">MarkToHTML</div>

            @* Polls — 108°, CSS 86%/62% *@
            <div class="node-base node-icon float-in" style="left: 86%; top: 62%;" title="Polls — Team voting">
                <img src="~/images/app_icons/polls.svg" alt="Polls" />
            </div>
            <div class="node-label float-in" style="left: 95%; top: 65%;">Polls</div>

            @* Employee Center — 144°, CSS 72%/81% *@
            <div class="node-base node-icon float-in" style="left: 72%; top: 81%;" title="Employee Center — HR portal">
                <img src="~/images/app_icons/employee.svg" alt="Employee Center" />
            </div>
            <div class="node-label float-in" style="left: 76%; top: 94%;">Employee</div>

            @* Kanban — 180°, CSS 50%/88% *@
            <div class="node-base node-icon float-in" style="left: 50%; top: 88%;" title="Kanban">
                <img src="~/images/app_icons/kanban.svg" alt="Kanban" />
            </div>
            <div class="node-label float-in" style="left: 50%; top: 99%; transform: translateX(-50%);">Kanban</div>

            @* AiurDrive — 216°, CSS 28%/81% *@
            <div class="node-base node-icon float-in" style="left: 28%; top: 81%;" title="AiurDrive — File storage">
                <img src="~/images/app_icons/aiurdrive.svg" alt="AiurDrive" />
            </div>
            <div class="node-label float-in" style="left: 24%; top: 94%;">AiurDrive</div>

            @* Warp — 252°, CSS 14%/62% *@
            <div class="node-base node-icon float-in" style="left: 14%; top: 62%;" title="Warp — URL shortener">
                <img src="~/images/app_icons/warp.svg" alt="Warp" />
            </div>
            <div class="node-label float-in" style="left: 4%; top: 65%;">Warp</div>

            @* Git Mirror — 288°, CSS 14%/38% *@
            <div class="node-base node-icon float-in" style="left: 14%; top: 38%;" title="Git Mirror — Repository sync">
                <img src="~/images/app_icons/gitmirror.svg" alt="Git Mirror" />
            </div>
            <div class="node-label float-in" style="left: 4%; top: 37%;">Git Mirror</div>

            @* C++ Runner — 324°, CSS 28%/19% *@
            <div class="node-base node-icon float-in" style="left: 28%; top: 19%;" title="C++ Runner — Online code execution">
                <img src="~/images/app_icons/cpprunner.svg" alt="C++ Runner" />
            </div>
            <div class="node-label float-in" style="left: 22%; top: 8%;">C++ Runner</div>

        </div>

        @* Mobile fallback: simple icon grid *@
        <div class="diagram-mobile-fallback flex-wrap justify-content-center gap-4 py-4" style="display: none;">
            <div class="text-center float-in">
                <img src="~/images/app_icons/authentik.webp" alt="Authentik" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Authentik</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/apkg.svg" alt="Apkg" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Apkg</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/kanban.svg" alt="Kanban" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Kanban</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/mth.svg" alt="Mark To HTML" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Mark To HTML</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/polls.svg" alt="Polls" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Polls</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/employee.svg" alt="Employee Center" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Employee Center</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/aiurdrive.svg" alt="AiurDrive" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">AiurDrive</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/nextcloud.webp" alt="Nextcloud" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Nextcloud</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/stathub.svg" alt="StatHub" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">StatHub</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/warp.svg" alt="Warp" width="48" height="48" class="rounded-3 mb-1"/>
                <div class="extra-small text-gray-400">Warp</div>
            </div>
            <div class="text-center float-in">
                <img src="~/images/app_icons/gitmirror.svg" alt="Git Mirror" width="48" height="48" class="rounded-3 mb-1"/>
