@model Aiursoft.CorpHome.Views.Shared.Components.MarketingNavbar.MarketingNavbarViewModel

<nav class="navbar navbar-expand-md navbar-dark bg-dark landing-navbar">
    <div class="container">
        <a class="navbar-brand landing-brand text-white" href="/">
            <img src="@Model.LogoUrl" alt="logo" style="width: 24px; height: 24px;" />
            @Model.ProjectName
        </a>
        <ul class="navbar-nav me-auto landing-mega-nav">
            <li class="nav-item dropdown dropdown-mega">
                <a class="nav-link dropdown-toggle active text-lg px-lg-3" href="#" id="navbarDropdownProducts" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @Localizer["Products"]
                </a>
                <div class="dropdown-menu dropdown-menu-dark dropdown-menu-end mega-menu-pane border-0 shadow-lg" aria-labelledby="navbarDropdownProducts">
                    <div class="container-fluid py-3 px-4">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <a href="https://www.anduinos.com" class="dropdown-item mega-item rounded p-3 d-flex align-items-start hover-bg-glass">
                                    <div class="me-3 flex-shrink-0"><img src="https://www.anduinos.com/favicon.svg" alt="AnduinOS" style="width:32px;height:32px;" /></div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-white">AnduinOS</h6>
                                        <small class="text-gray-400 text-wrap">AnduinOS is a custom Ubuntu-based Linux distribution that offers a familiar and easy-to-use experience for anyone moving to Linux.</small>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-6 mb-3">
                                <a href="https://template.aiursoft.com" class="dropdown-item mega-item rounded p-3 d-flex align-items-start hover-bg-glass">
                                    <div class="me-3 flex-shrink-0"><img src="https://template.aiursoft.com/favicon.svg" alt="Template" style="width:32px;height:32px;" /></div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-white">Template</h6>
                                        <small class="text-gray-400 text-wrap">Enterprise business framework for the Open-source &amp; AI era.</small>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-6 mb-3">
                                <a href="https://ollamagateway.aiursoft.com" class="dropdown-item mega-item rounded p-3 d-flex align-items-start hover-bg-glass">
                                    <div class="me-3 flex-shrink-0"><img src="https://ollama.aiursoft.com/favicon.svg" alt="OllamaGateway" style="width:32px;height:32px;" /></div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-white">Ollama Gateway</h6>
                                        <small class="text-gray-400 text-wrap">Supercharge your native Ollama with enterprise-grade API authentication, request auditing, and virtual model management—your secure, private AI gateway.</small>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-6 mb-3">
                                <a href="https://stathub.aiursoft.com" class="dropdown-item mega-item rounded p-3 d-flex align-items-start hover-bg-glass">
                                    <div class="me-3 flex-shrink-0"><img src="https://stathub.aiursoft.com/favicon.svg" alt="StatHub" style="width:32px;height:32px;" /></div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-white">StatHub</h6>
                                        <small class="text-gray-400 text-wrap">A simple, real-time server monitoring system designed for local deployment. Keep an eye on your infrastructure with intuitive dashboards and detailed metrics.</small>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
            <li class="nav-item dropdown dropdown-mega">
                <a class="nav-link dropdown-toggle active text-lg px-lg-3" href="#" id="navbarDropdownSolutions" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @Localizer["Solutions"]
                </a>
                <div class="dropdown-menu dropdown-menu-dark dropdown-menu-end mega-menu-pane border-0 shadow-lg" aria-labelledby="navbarDropdownSolutions">
                    <div class="container-fluid py-3 px-4">
                        <div class="row">
                            <div class="col-md-12">
                                <a asp-controller="Home" asp-action="Substratum" class="dropdown-item mega-item rounded p-3 d-flex align-items-start hover-bg-glass">
                                    <div class="me-3 flex-shrink-0"><img src="/favicon.svg" alt="Substratum" style="width:32px;height:32px;" /></div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-white">Substratum</h6>
                                        <small class="text-gray-400 text-wrap">Unified endpoint management (UEM), identity management (IAM), and collaboration tools (OA) in one package. All on your local servers!</small>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
            <li class="nav-item dropdown dropdown-mega">
                <a class="nav-link dropdown-toggle active text-lg px-lg-3" href="#" id="navbarDropdownPartners" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @Localizer["Partners"]
                </a>
                <div class="dropdown-menu dropdown-menu-dark dropdown-menu-end mega-menu-pane border-0 shadow-lg" aria-labelledby="navbarDropdownPartners">
                    <div class="container-fluid py-3 px-4">
                        <div class="row">
                            <div class="col-12 text-center py-4">
                                <p class="text-gray-400 mb-0">Join our partner ecosystem.</p>
                                <h5 class="text-white mt-2 mb-3">Discover the benefits of working with us.</h5>
                                <a href="#" class="btn btn-outline-light btn-sm px-4 rounded-pill">View Partners</a>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
        </ul>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-lg btn-primary btn-pill my-2 my-sm-0 ms-3">
            <i class="align-middle" data-lucide="rocket"></i> @Localizer["Try the dashboard"]
        </a>
        <a href="https://github.com/aiursoftweb/template" target="_blank" rel="noreferer" class="btn btn-lg btn-outline-light btn-pill my-2 my-sm-0 ms-3">
            <i class="fa-brands fa-github me-1"></i> @Localizer["GitHub"]
        </a>
    </div>
</nav>
