@model Aiursoft.CorpHome.Views.Shared.Components.SubstratumPricing.SubstratumPricingViewModel

<section class="py-5 bg-white" id="enterprise-packages">
    <div class="container">
        <div class="row">
            <div class="col-md-12 col-xl-10 col-xxl-10 mx-auto">
                <div class="mb-4 text-center">
                    <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Pricing"]</span>
                    <h2 class="h1">@Localizer["Get a public cloud-like experience while hosting your applications in your own server."]</h2>
                    <p class="text-muted fs-lg">@Localizer["Strengthen your business with flexible Open Source projects that run by Aiursoft."]</p>
                </div>
                <div class="row py-4">

                    @* Starter Enterprise *@
                    <div class="col-md-4 mb-5 mb-md-0">
                        <div class="card text-center h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="mb-4">
                                    <h5><img src="~/favicon.svg" class="align-top me-1" style="height: 1em;" alt="Aiursoft Logo"> @Localizer["Aiursoft Substratum Core"]</h5>
                                    <span class="display-5">@Model.PriceStarter</span><br/>
                                    <span>@Localizer["/ user"] @Localizer["/ month"]</span>
                                </div>
                                <h6 class="mt-3">@Localizer["Includes Collaboration + Email + Identity Gateway"]</h6>
                                <ul class="list-unstyled mt-3">
                                    <li class="mb-2">@Localizer["Hosted by Aiursoft"]</li>
                                    <li class="mb-2">Mailcow</li>
                                    <li class="mb-2">Authentik</li>
                                    <li class="mb-2">Employee Center</li>
                                    <li class="mb-2">MarkToHtml, Polls</li>
                                    <li class="mb-2">@Localizer["Max 150 accounts"]</li>
                                </ul>
                                <div class="mt-auto">
                                    <a asp-controller="Home" asp-action="Contact" class="btn btn-lg btn-pill btn-outline-primary">@Localizer["Get Started"]</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Startup Enterprise *@
                    <div class="col-md-4 mb-5 mb-md-0">
                        <div class="card text-center h-100 middle-card border-primary">
                            <div class="card-body d-flex flex-column">
                                <div class="mb-4">
                                    <h5><img src="~/favicon.svg" class="align-top me-1" style="height: 1em;" alt="Aiursoft Logo"> @Localizer["Aiursoft Substratum Startup"]</h5>
                                    <span class="display-5">@Model.PriceStartup</span><br/>
                                    <span>@Localizer["/ user"] @Localizer["/ month"]</span>
                                    <div class="text-muted small">
                                        + @Localizer["One-time Setup Fee"]<sup class="text-muted fw-normal fs-sm">1</sup>
                                    </div>
                                </div>
                                <h6 class="mt-3">@Localizer["Full Infrastructure Suite, on your local server"]</h6>
                                <ul class="list-unstyled mt-3">
                                    <li class="mb-2">@Localizer["Includes everything in Starter"]</li>
                                    <li class="mb-2">@Localizer["On-premise offline deployment"]</li>
                                    <li class="mb-2">@Localizer["AnduinOS Enterprise"]</li>
                                    <li class="mb-2">@Localizer["Zero Trust Yubikey Auth"]</li>
                                    <li class="mb-2">AiurDrive, StatHub, Nextcloud</li>
                                    <li class="mb-2">Koel, Immich, Memos</li>
                                    <li class="mb-2">@Localizer["Max 1000 accounts"]</li>
                                    <li class="mb-2">
                                        <span class="badge badge-subtle-primary">@Localizer["Recommended"]</span>
                                    </li>
                                </ul>
                                <div class="mt-auto">
                                    <a asp-controller="Home" asp-action="Contact" class="btn btn-lg btn-pill btn-primary">@Localizer["Talk to an Architect"]</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Custom Enterprise *@
                    <div class="col-md-4 mb-5 mb-md-0">
                        <div class="card text-center h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="mb-4">
                                    <h5><img src="~/favicon.svg" class="align-top me-1" style="height: 1em;" alt="Aiursoft Logo"> @Localizer["Aiursoft Substratum Enterprise"]</h5>
                                    <span class="display-5">@Model.PriceCustom</span><br/>
                                    <span>@Localizer["/ user"] @Localizer["/ month"]</span>
                                    <div class="text-muted small">
                                        + @Localizer["Custom Development Fee"]<sup class="text-muted fw-normal fs-sm">3</sup>
                                    </div>
                                </div>
                                <h6 class="mt-3">@Localizer["Customized for your enterprise"]</h6>
                                <ul class="list-unstyled mt-3">
                                    <li class="mb-2">@Localizer["Includes everything in Startup"]</li>
                                    <li class="mb-2">@Localizer["Enterprise scale deployment"]</li>
                                    <li class="mb-2">GitLab, Ollama Gateway</li>
                                    <li class="mb-2">@Localizer["AI Knowledge Base construction"]<sup class="text-muted fw-normal fs-sm">2</sup></li>
                                    <li class="mb-2">@Localizer["MDM based device compliance"]</li>
                                    <li class="mb-2">@Localizer["Custom container development"]</li>
                                    <li class="mb-2">@Localizer["tailored to your business needs"]</li>
                                </ul>
                                <div class="mt-auto">
                                    <a asp-controller="Home" asp-action="Contact" class="btn btn-lg btn-pill btn-outline-primary">@Localizer["Contact Sales"]</a>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="text-muted small mt-5">
                    <p class="mb-1"><sup>1</sup> @Localizer["One-time setup fee needs to be discussed based on your deployment mode, generally around {0}.", Model.SetupFeeEstimate]</p>
                    <p class="mb-1"><sup>2</sup> @Localizer["To build your offline AI knowledge base, you may need to purchase an NVIDIA GPU. This may require additional payment to NVIDIA corporation."]</p>
                    <p class="mb-0"><sup>3</sup> @Localizer["Specific fees need to be discussed with our architecture team to determine how to build for your enterprise."]</p>
                </div>
            </div>
        </div>
    </div>
</section>
