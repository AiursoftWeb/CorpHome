@model Aiursoft.CorpHome.Models.HomeViewModels.KnowUsViewModel
@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <span class="badge badge-subtle-primary p-1">@Localizer["About Aiursoft"]</span>
                <h1 class="my-4 text-white" style="font-size: 2.5rem;">
                    @Localizer["Aiursoft is dedicated to bringing the spirit of open-source and free software to every enterprise and individual."]
                </h1>
            </div>
        </div>
    </div>
</section>

@* Chapter 1: Our Story *@
<section class="py-6 bg-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">@Localizer["Chapter 1"]</span>
                <p class="fs-5 text-muted">
                    @Localizer["Aiursoft's story is closely linked to the communities that shape us, including the global community of open source contributors and enthusiasts who are part of our team. Since 2025, we have built an operating system called AnduinOS — designed to be clean, simple, and accessible to everyone."]
                </p>
            </div>
        </div>
    </div>
</section>

@* Company Culture *@
<section class="py-6 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="h1">@Localizer["Our Culture"]</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="text-center p-4">
                    <div class="icon-box-lg bg-primary-subtle text-primary rounded-circle mx-auto mb-4">
                        <i data-lucide="lock-open" style="width: 1.75rem; height: 1.75rem;"></i>
                    </div>
                    <h3 class="fw-bold">@Localizer["Freedom"]</h3>
                    <p class="text-muted">@Localizer["We open-source everything we build. We reject vendor lock-in and ecosystem entrapment. We respect open standards, champion offline-first operation, and believe every right to the code belongs to the customer and the device owner. We build nothing that stands between software users and their freedom to tinker — no barriers, no gatekeeping, no artificial constraints on what a hacker or user can do with the tools we create."]</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="text-center p-4">
                    <div class="icon-box-lg bg-success-subtle text-success rounded-circle mx-auto mb-4">
                        <i data-lucide="sprout" style="width: 1.75rem; height: 1.75rem;"></i>
                    </div>
                    <h3 class="fw-bold">@Localizer["Growth"]</h3>
                    <p class="text-muted">@Localizer["For every team member, personal growth comes first — above profit, above deadlines. We design work so that it is accessible without deep prior familiarity: the best learning happens through hands-on exploration, not prerequisites. We value playfulness and genuine curiosity — the kind that makes you lose track of time. When our people grow, the company grows as a natural consequence, not the other way around."]</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="text-center p-4">
                    <div class="icon-box-lg bg-warning-subtle text-warning rounded-circle mx-auto mb-4">
                        <i data-lucide="clock" style="width: 1.75rem; height: 1.75rem;"></i>
                    </div>
                    <h3 class="fw-bold">@Localizer["Long-term"]</h3>
                    <p class="text-muted">@Localizer["Aiursoft is built to last a century. We are just getting started. Every decision we make serves a blueprint measured in decades, not quarters. We resist the urge to chase short-term hype or fleeting trends. Our choices are deliberate, steady, and patient — because the work that truly matters takes time, and we intend to be here for all of it."]</p>
                </div>
            </div>
        </div>
    </div>
</section>

