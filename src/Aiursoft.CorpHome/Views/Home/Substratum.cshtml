@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script src="~/scripts/lucide.min.js"></script>
    <script>lucide.createIcons();</script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const observer = new IntersectionObserver((entries) => {
                let delay = 0;
                entries.forEach(entry => {
                    if (entry.isIntersecting && !entry.target.classList.contains('float-in-visible')) {
                        setTimeout(() => {
                            entry.target.classList.add('float-in-visible');
                        }, delay);
                        delay += 50;
                    }
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('.float-in').forEach(el => observer.observe(el));
        });
    </script>
}
