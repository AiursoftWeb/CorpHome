@* ReSharper disable once Razor.SectionNotResolved *@
@model Aiursoft.CorpHome.Models.HomeViewModels.AnduinosViewModel
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 1: Community Hero
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row align-items-center h-100">
            <div class="col-lg-5 mx-auto">
                <span class="badge badge-subtle-primary p-1">@Localizer["Open Source"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["Free"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["GPL-v3 License"]</span>
                <h1 id="main-slogan" class="my-4 text-white" style="font-size: 3rem;">
                    @Localizer["Love AnduinOS?"] <span class='text-primary'>@Localizer["Deploy at scale, manage centrally, enjoy the enterprise edition!"]</span>
                </h1>
                <p class="text-lg text-white-50">@Localizer["AnduinOS is a custom Ubuntu-based Linux distribution that offers a familiar and easy-to-use experience for anyone moving to Linux."]</p>
                <div class="my-4">
                    <span class="badge badge-subtle-primary p-1">v2.0.0</span>
                </div>
                <div class="my-4">
                    <a class="btn btn-primary btn-lg btn-pill" href="https://www.anduinos.com/#download-links" target="_blank">
                        <i class="fa-solid fa-download me-1"></i>@Localizer["Download AnduinOS"]
                    </a>
                    <a href="https://docs.anduinos.com" target="_blank" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle me-1" data-lucide="book-open"></i>@Localizer["Docs"]
                    </a>
                </div>
                <div class="my-3">
                    <a href="https://www.anduinos.com" target="_blank" class="btn btn-outline-light btn-pill">
                        <i class="align-middle me-1" data-lucide="globe"></i>@Localizer["Community Site"]
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-light btn-pill ms-2">
                        <i class="align-middle me-1" data-lucide="headphones"></i>@Localizer["Contact Enterprise Sales"]
                    </a>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex mx-auto text-center">
                <div class="landing-intro-screenshot">
                    <img src="~/images/anduinos-sc.webp" alt="AnduinOS Screenshot" class="img-fluid rounded-3 shadow-lg" />
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 2: Why choose AnduinOS?
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Reasons"]</span>
            <h2 class="h1">@Localizer["Why choose AnduinOS?"]</h2>
            <p class="text-muted fs-lg">@Localizer["Smaller image, friendly interface, unbeatable performance, safe and secure."]</p>
        </div>
        <div class="row text-start">
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="sliders"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Ready to use"]</h4>
                        <p class="fs-lg">@Localizer["The ISO is just 2.4GB in size. Similar to Ubuntu, it is simple to install and can meet your daily needs without additional configuration or complicated operations."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="smartphone"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Friendly interface"]</h4>
                        <p class="fs-lg">@Localizer["The GNOME-based desktop environment has beautiful interfaces and human-computer interactions that fit user habits, allowing you to quickly get started with AnduinOS without too much learning cost."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="mail"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Root and privacy"]</h4>
                        <p class="fs-lg">@Localizer["Privacy is no longer optional. It's essential. AnduinOS is designed to gather nothing from you. We don't track you. We don't profile you. We don't target you. You remain anonymous to the system."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="chrome"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Ecological perfection"]</h4>
                        <p class="fs-lg">@Localizer["AnduinOS is based on Ubuntu's package base. It's compatible with most of the apt packages from Ubuntu. It's a perfect combination of experience and ecology."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="code-2"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Open Source"]</h4>
                        <p class="fs-lg">@Localizer["AnduinOS is an open-source project. Following the GPL-v3 license, you can view the source code, modify it, and redistribute it. It's free and will always be free."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="box"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Containerized"]</h4>
                        <p class="fs-lg">@Localizer["Graphical applications are installed via Flatpak, and keep themselves separate from the base system. They also allow for fine-grained control over their permissions."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 3: Enterprise Divider
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="py-5" style="background: linear-gradient(135deg, #0a2a66 0%, #161a27 100%);">
    <div class="container text-center">
        <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
            <span class="text-primary me-2"><i data-lucide="building-2"></i></span>
            <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["AnduinOS Enterprise"]</span>
        </div>
        <h2 class="display-4 fw-bold text-white mb-3">@Localizer["Built for business. Air-gapped by design."]</h2>
        <p class="lead text-gray-400 mb-0">@Localizer["All the power of open-source, backed by enterprise-grade support, management tools, and customisation capabilities."]</p>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 5: Kiosk & Digital Signage
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="immersive-section position-relative w-100 overflow-hidden d-flex align-items-center border-top border-white-10" style="min-height: 800px;">
    <div class="immersive-bg-right">
        <div class="bg-image-wrapper clean-wrapper">
            <img src="~/images/anduinos-sc.webp" alt="@Localizer["AnduinOS Kiosk"]" class="img-fluid object-fit-cover w-100 h-100">
        </div>
        <div class="bg-overlay"></div>
    </div>
    <div class="container position-relative z-2 py-5">
        <div class="row">
            <div class="col-lg-6 col-md-12">
                <div class="mb-5 text-start pe-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-info me-2"><i data-lucide="monitor"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Kiosk & Digital Signage"]</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        @Localizer["The ideal solution for"]<br>
                        <span class="text-primary">@Localizer["digital signage and kiosk terminals"]</span>
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        @Localizer["Transform any PC into a secure, managed kiosk. Our in-house kiosk content management suite is available now — try it today."]
                    </p>
                </div>
                <div class="row g-3 pe-lg-4">
                    <div class="col-md-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-info-subtle text-info rounded-3 mb-3">
                                    <i data-lucide="monitor-up"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Turn any screen into a kiosk"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm">@Localizer["Deploy interactive kiosks, information displays, and self-service terminals on standard PC hardware."]</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-warning-subtle text-warning rounded-3 mb-3">
                                    <i data-lucide="lock"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Locked-down & tamper-proof"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm">@Localizer["Kiosk mode prevents unauthorized access. Users can only interact with your approved application, keeping your deployment secure."]</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4 d-flex align-items-center">
                                <div class="icon-box-sm bg-white-10 text-white rounded-3 me-3">
                                    <i data-lucide="wifi"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-white mb-1 fs-6">@Localizer["Remote content management"]</h5>
                                    <p class="text-gray-400 mb-0">@Localizer["Update content, push configurations, and monitor device health — all from the cloud. No need for on-site visits."]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 6: Speedy Makeover
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border bg-dark-glass-sm">
                <span class="text-warning me-2"><i data-lucide="zap"></i></span>
                <span class="small fw-medium text-uppercase tracking-wider">@Localizer["Performance"]</span>
            </div>
            <h2 class="display-4 fw-bold mb-3">@Localizer["Speedy Makeover"]</h2>
            <p class="lead text-muted">@Localizer["Tired of your sluggish OS slowing you down? Switch to AnduinOS for instant speed and seamless performance."]</p>
        </div>
        <div class="row text-center g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 transition-hover">
                    <div class="card-body p-5">
                        <div class="icon-box-lg bg-primary-subtle text-primary rounded-circle mx-auto mb-4">
                            <i data-lucide="timer" style="width: 2rem; height: 2rem;"></i>
                        </div>
                        <h3 class="fw-bold mb-2">@Localizer["Stable & Modern"]</h3>
                        <p class="text-muted mb-0">@Localizer["The operating system your enterprise needs — familiar, beautiful, stable, mature, and easy to manage. AnduinOS Enterprise is built on Linux 7.0, GNOME 50, and Ubuntu 26.04, keeping your team in a comfortable, productive environment."]</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 transition-hover">
                    <div class="card-body p-5">
                        <div class="icon-box-lg bg-success-subtle text-success rounded-circle mx-auto mb-4">
                            <i data-lucide="leaf" style="width: 2rem; height: 2rem;"></i>
                        </div>
                        <h3 class="fw-bold mb-2">@Localizer["Resource Efficient"]</h3>
                        <p class="text-muted mb-0">@Localizer["Runs smoothly on older devices. Extends hardware lifespan by being resource-efficient, so you don't need to buy new machines."]</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 transition-hover">
                    <div class="card-body p-5">
                        <div class="icon-box-lg bg-info-subtle text-info rounded-circle mx-auto mb-4">
                            <i data-lucide="refresh-cw" style="width: 2rem; height: 2rem;"></i>
                        </div>
                        <h3 class="fw-bold mb-2">@Localizer["Auto Updates on Reboot"]</h3>
                        <p class="text-muted mb-0">@Localizer["System updates apply automatically when you restart. Zero maintenance windows — just reboot, and you're on the latest version."]</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <p class="text-muted">@Localizer["Simple, user-friendly. Broad compatibility with virtually all PC hardware."]</p>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 7: AnduinOS Enterprise — Specifications
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="position-relative py-6 overflow-hidden" style="background-color: #0b0d14;">
    @* Cyber Grid Background *@
    <svg class="position-absolute top-0 start-0 w-100 h-100 opacity-10" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" style="pointer-events: none; z-index: 0;">
        <g stroke="#0ea5e9" stroke-width="0.5" opacity="0.3">
            <path d="M 0 100 L 800 100 M 0 200 L 800 200 M 0 300 L 800 300 M 0 400 L 800 400 M 0 500 L 800 500" />
            <path d="M 100 0 L 100 600 M 200 0 L 200 600 M 300 0 L 300 600 M 400 0 L 400 600 M 500 0 L 500 600 M 600 0 L 600 600 M 700 0 L 700 600" />
        </g>
    </svg>

    <div class="container position-relative z-2">
        <div class="text-center mb-5">
            <h2 class="display-4 fw-bold text-white"><span class="text-primary">AnduinOS</span> @Localizer["Enterprise"]</h2>
            <p class="lead text-gray-400">@Localizer["Built on a rock-solid foundation. Designed for the enterprise."]</p>
        </div>

        @* Feature Badges *@
        <div class="d-flex flex-wrap justify-content-center gap-2 mb-5">
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Familiar UX"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">2.5 GB</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Live Boot"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["LTS Support"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Without Snap"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Free Software"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["NVIDIA Graphics Support"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Secure Boot"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Ubuntu Base"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["Wayland Ready"]</span>
            <span class="badge bg-dark-glass border-white-10 text-gray-300 px-3 py-2 rounded-pill">@Localizer["HDR Support"]</span>
        </div>

        <div class="row g-4">
            @* Left: Tech Specs *@
            <div class="col-lg-6">
                <div class="card bg-dark-glass border-white-10 h-100">
                    <div class="card-header bg-transparent border-white-10 pt-4">
                        <h4 class="mb-0 text-white">@Localizer["Technical Specifications"]</h4>
                    </div>
                    <div class="card-body pt-0">
                        <table class="table table-borderless mb-0">
                            <tbody>
                                <tr><td class="text-gray-500 ps-0" style="width: 40%;">@Localizer["Release Date"]</td><td class="text-white fw-semibold pe-0">2026-06-30</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["End of Support"]</td><td class="text-white fw-semibold pe-0">April 2041</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Pricing"]</td><td class="fw-semibold pe-0"><a asp-controller="Home" asp-action="Contact" class="text-primary">@Localizer["Contact Sales"]</a></td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Image Size"]</td><td class="text-white fw-semibold pe-0">2.5 GB</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Linux Kernel"]</td><td class="text-white fw-semibold pe-0">7.0.0</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Desktop Environment"]</td><td class="text-white fw-semibold pe-0">GNOME 52</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Display Server"]</td><td class="text-white fw-semibold pe-0">Wayland</td></tr>
                            </tbody>
                        </table>
                        @* Collapsible Advanced Specs *@
                        <div class="collapse" id="advancedSpecs">
                            <table class="table table-borderless mb-0">
                                <tbody>
                                    <tr><td class="text-gray-500 ps-0" style="width: 40%;">@Localizer["UI Toolkit"]</td><td class="text-white fw-semibold pe-0">GTK4</td></tr>
                                    <tr><td class="text-gray-500 ps-0">@Localizer["Package Manager"]</td><td class="text-white fw-semibold pe-0">apt</td></tr>
                                    <tr><td class="text-gray-500 ps-0">@Localizer["Package Format"]</td><td class="text-white fw-semibold pe-0">deb + Flatpak</td></tr>
                                    <tr><td class="text-gray-500 ps-0">@Localizer["Architecture"]</td><td class="text-white fw-semibold pe-0">x86_64</td></tr>
                                    <tr><td class="text-gray-500 ps-0">@Localizer["Init System"]</td><td class="text-white fw-semibold pe-0">systemd</td></tr>
                                    <tr><td class="text-gray-500 ps-0">@Localizer["Default Filesystem"]</td><td class="text-white fw-semibold pe-0">ext4</td></tr>
                                    <tr><td class="text-gray-500 ps-0">@Localizer["Default Browser"]</td><td class="text-white fw-semibold pe-0">Firefox</td></tr>
                                </tbody>
                            </table>
                        </div>
                        <button class="btn btn-sm btn-outline-light rounded-pill mt-2" type="button" data-bs-toggle="collapse" data-bs-target="#advancedSpecs" aria-expanded="false">
                            <i data-lucide="chevron-down" class="me-1" style="width: 14px; height: 14px;"></i>@Localizer["Advanced"]
                        </button>
                    </div>
                </div>
            </div>
            @* Right: System Requirements *@
            <div class="col-lg-6">
                <div class="card bg-dark-glass border-white-10 h-100">
                    <div class="card-header bg-transparent border-white-10 pt-4">
                        <h4 class="mb-0 text-white">@Localizer["System Requirements"]</h4>
                    </div>
                    <div class="card-body pt-0">
                        <table class="table table-borderless mb-0">
                            <tbody>
                                <tr><td class="text-gray-500 ps-0" style="width: 40%;">@Localizer["Architecture"]</td><td class="text-white fw-semibold pe-0">x86_64</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Firmware"]</td><td class="text-white fw-semibold pe-0">UEFI @Localizer["or"] BIOS</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Processor"]</td><td class="text-white fw-semibold pe-0">2 GHz</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["RAM"]</td><td class="text-white fw-semibold pe-0">4 GB</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Disk Space"]</td><td class="text-white fw-semibold pe-0">20 GB</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Screen"]</td><td class="text-white fw-semibold pe-0">1024 × 768</td></tr>
                                <tr><td class="text-gray-500 ps-0">@Localizer["Ports"]</td><td class="text-white fw-semibold pe-0">USB @Localizer["or"] DVD</td></tr>
                            </tbody>
                        </table>
                        <div class="mt-3 p-3 bg-dark-glass rounded-3 text-center text-gray-400 small border-white-10 border">
                            <i data-lucide="info" class="me-1" style="width: 14px; height: 14px;"></i>
                            @Localizer["Compatible with most x86 PCs manufactured in the last decade."]
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════════
   SECTION 8: Enterprise Services
   ═══════════════════════════════════════════════════════════════════════════════ *@
<section class="position-relative py-6 overflow-hidden" style="background-color: #0b0d14;">
    @* Cyberpunk Grid Background *@
    <svg class="position-absolute top-0 start-0 w-100 h-100 opacity-20" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" style="pointer-events: none; z-index: 0;">
        <defs>
            <filter id="neon-glow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3" result="blur"/>
                <feMerge>
                    <feMergeNode in="blur"/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
        </defs>
        <g stroke="#0ea5e9" stroke-width="0.5" opacity="0.15">
            <path d="M 0 100 L 800 100 M 0 200 L 800 200 M 0 300 L 800 300 M 0 400 L 800 400 M 0 500 L 800 500" />
            <path d="M 100 0 L 100 600 M 200 0 L 200 600 M 300 0 L 300 600 M 400 0 L 400 600 M 500 0 L 500 600 M 600 0 L 600 600 M 700 0 L 700 600" />
        </g>
        <circle cx="400" cy="300" r="200" fill="none" stroke="#0ea5e9" stroke-width="0.5" opacity="0.08" filter="url(#neon-glow)" />
